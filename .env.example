PORT=3000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=github_analyzer

# GitHub Personal Access Token (optional but recommended — raises rate limit from 60 to 5000 req/hr)
# Generate at: https://github.com/settings/tokens (no scopes needed)
GITHUB_TOKEN=ghp_your_token_here

# Rate Limiting (optional — defaults shown below)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
